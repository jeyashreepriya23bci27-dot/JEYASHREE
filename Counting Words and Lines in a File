#include <stdio.h>
#include <ctype.h>

int main() {
    FILE *fp = fopen("notes.txt", "r");
    char ch;
    int words = 0, lines = 0, characters = 0;
    int inWord = 0;

    if (fp == NULL) return 1;

    while ((ch = fgetc(fp)) != EOF) {
        characters++;
        if (ch == '\n') lines++;

        // Logic to detect a word boundary
        if (isspace(ch)) {
            inWord = 0;
        } else if (inWord == 0) {
            inWord = 1;
            words++;
        }
    }

    printf("Lines: %d\nWords: %d\nChars: %d\n", lines, words, characters);
    fclose(fp);
    return 0;
}
