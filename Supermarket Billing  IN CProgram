#include <stdio.h>
#include <string.h>

struct Item {
    char name[30];
    int qty;
    float price;
    float total;
};

int main() {
    struct Item items[20];
    int n, i;
    float subTotal = 0, gst, discount = 0, grandTotal;

    printf("--- SUPERMARKET BILLING SYSTEM ---\n");
    printf("Enter number of items purchased: ");
    scanf("%d", &n);


    for (i = 0; i < n; i++) {
        printf("\nItem %d Name: ", i + 1);
        scanf("%s", items[i].name);
        printf("Quantity: ");
        scanf("%d", &items[i].qty);
        printf("Price per unit: ");
        scanf("%f", &items[i].price);
        
        items[i].total = items[i].qty * items[i].price;
        subTotal += items[i].total;
    }

    gst = subTotal * 0.05; // 5% GST
    if (subTotal >= 1000) {
        discount = subTotal * 0.15; // 15% discount for bills over 1000
    }
    grandTotal = (subTotal + gst) - discount;


    printf("\n\n================ RECEIPT ================\n");
    printf("%-15s %-5s %-10s %-10s\n", "Item", "Qty", "Price", "Total");
    printf("-----------------------------------------\n");
    for (i = 0; i < n; i++) {
        printf("%-15s %-5d %-10.2f %-10.2f\n", 
               items[i].name, items[i].qty, items[i].price, items[i].total);
    }
    printf("-----------------------------------------\n");
    printf("Sub-Total:    Rs. %.2f\n", subTotal);
    printf("GST (5%%):     Rs. %.2f\n", gst);
    printf("Discount:     Rs. %.2f\n", discount);
    printf("=========================================\n");
    printf("GRAND TOTAL:  Rs. %.2f\n", grandTotal);
    printf("=========================================\n");
    printf("       THANK YOU FOR SHOPPING!           \n");

    return 0;
}
