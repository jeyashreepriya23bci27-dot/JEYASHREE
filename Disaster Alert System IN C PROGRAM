#include <stdio.h>
#include <string.h>

struct Disaster {
    char location[30];
    float value;      
    char type[15];    
};

void logDisaster() {
    FILE *fp = fopen("disaster_logs.txt", "a");
    struct Disaster d;

    printf("\nEnter Location: ");
    scanf("%s", d.location);
    printf("Enter Type (Flood/Earthquake): ");
    scanf("%s", d.type);
    
    if (strcasecmp(d.type, "Flood") == 0) {
        printf("Enter Water Level (in meters): ");
    } else {
        printf("Enter Magnitude (Richter scale): ");
    }
    scanf("%f", &d.value);

    fprintf(fp, "%-12s | %-15s | %.2f\n", d.type, d.location, d.value);
    fclose(fp);

    printf("\n--- SYSTEM ALERT ---");
    if (strcasecmp(d.type, "Flood") == 0 && d.value > 5.0) {
        printf("\n⚠️ WARNING: Water level at %.2fm in %s is CRITICAL! Evacuate now.\n", d.value, d.location);
    } else if (strcasecmp(d.type, "Earthquake") == 0 && d.value > 6.0) {
        printf("\n🛑 DANGER: Magnitude %.1f in %s is SEVERE! Prepare for aftershocks.\n", d.value, d.location);
    } else {
        printf("\nReading logged. Status: Normal.\n");
    }
}

void viewHistory() {
    char line[100];
    FILE *fp = fopen("disaster_logs.txt", "r");
    if (!fp) {
        printf("No records available.\n");
        return;
    }

    printf("\n--- Historical Disaster Logs ---\n");
    printf("Type         | Location        | Reading\n");
    printf("------------------------------------------\n");
    while (fgets(line, sizeof(line), fp)) {
        printf("%s", line);
    }
    fclose(fp);
}

int main() {
    int choice;
    while(1) {
        printf("\n1. Log New Sensor Reading\n2. View History\n3. Exit\nChoice: ");
        scanf("%d", &choice);
        if(choice == 1) logDisaster();
        else if(choice == 2) viewHistory();
        else break;
    }
    return 0;
}
